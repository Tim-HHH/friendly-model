<Window x:Class="ModelHotSwapWorkflow.Views.TcpConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="全局通信参数配置" Height="480" Width="580" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="基础通信协议配置" Grid.Row="0" Margin="0,0,0,15" BorderBrush="#ACBAD1">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbServer" Content="TCP 服务端 (Server)" Margin="0,0,20,0" IsChecked="True"/>
                    <RadioButton x:Name="RbClient" Content="TCP 客户端 (Client)"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="主机地址:" VerticalAlignment="Center" Width="65"/>
                    <TextBox x:Name="TxtAddress" Width="110" Margin="0,0,20,0"/>

                    <TextBlock Text="TCP 端口:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtPort" Width="60" Margin="0,0,20,0"/>

                    <TextBlock Text="HTTP 端口:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtHttpPort" Width="60"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="本地调试与仿真配置" Grid.Row="1" Margin="0,0,0,15" BorderBrush="#ACBAD1">
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBlock Text="手动触发模式下默认仿真指令:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBox x:Name="TxtManualCommand" Width="120" VerticalAlignment="Center" ToolTip="在手动模式下点击运行时，系统将模拟接收此指令"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="指令路由映射表 (外部指令 ➔ 关联图像源)" Grid.Row="2" Margin="0,0,0,15" BorderBrush="#ACBAD1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="IcMappings">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="触发指令:" VerticalAlignment="Center" Margin="0,0,8,0" Grid.Column="0"/>
                                    <TextBox Grid.Column="1" Text="{Binding CommandText}" Width="100" Margin="0,0,20,0" ToolTip="对应上位机发送的 X-Command 标识"/>

                                    <TextBlock Text="目标起始节点:" VerticalAlignment="Center" Foreground="#666666" Margin="0,0,8,0" Grid.Column="2" HorizontalAlignment="Left"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableSources}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding TargetSourceId}" Width="180" HorizontalAlignment="Right"/>

                                    <Button Grid.Column="3" Content="移除" Width="45" Margin="12,0,0,0" Click="BtnRemoveMapping_Click" Tag="{Binding}" Background="#FEE9E9" BorderBrush="#FFC1C1"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="1" Content="+ 添加路由映射规则" Click="BtnAddMapping_Click" Height="32" Margin="0,12,0,0" Background="#F0F5FF" BorderBrush="#ADC6FF"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="应用配置" Width="110" Height="36" Click="BtnOk_Click" Background="#007ACC" Foreground="White" Margin="0,0,12,0" BorderThickness="0"/>
            <Button Content="取消" Width="90" Height="36" Click="BtnCancel_Click" Background="#F5F5F5"/>
        </StackPanel>
    </Grid>
</Window>