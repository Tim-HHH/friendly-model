<Window x:Class="ModelHotSwapWorkflow.Views.ModelConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模型推理引擎配置" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" Background="#2D2D2D" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="推理节点参数配置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="输入数据源 (Input Source):" Margin="0,10,0,5" Foreground="#AAAAAA"/>
            <ComboBox x:Name="SourceComboBox" Height="30" Background="#3E3E42" Foreground="White"/>

            <TextBlock Text="ONNX 模型路径 (Model Path):" Margin="0,15,0,5" Foreground="#AAAAAA"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ModelPathTextBox" Height="30" IsReadOnly="True" VerticalContentAlignment="Center"
                         Background="#3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#555555"/>
                <Button Grid.Column="1" Content="浏览..." Click="BrowseModel_Click" Margin="5,0,0,0" 
                        Background="#007ACC" Foreground="White" BorderThickness="0"/>
            </Grid>

            <UniformGrid Columns="2" Margin="0,20,0,0">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="置信度阈值 (Confidence):" Foreground="#AAAAAA"/>
                    <Slider x:Name="ConfidenceSlider" Minimum="0" Maximum="1" TickFrequency="0.01" Margin="0,5"/>
                    <TextBlock Text="{Binding ElementName=ConfidenceSlider, Path=Value, StringFormat={}{0:F2}}" 
                               HorizontalAlignment="Right" Foreground="Gold"/>
                </StackPanel>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <CheckBox x:Name="GpuCheckBox" Content="开启 GPU 加速 (CUDA)" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="* 需要 ONNX Runtime GPU 支持" FontSize="10" Foreground="#666666" Margin="20,5,0,0"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="确认保存" Click="Ok_Click" Width="100" Height="30" Margin="10,0" Background="#28A745" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="Cancel_Click" Width="80" Height="30" Background="#6C757D" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>