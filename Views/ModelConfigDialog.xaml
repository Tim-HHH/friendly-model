<Window x:Class="ModelHotSwapWorkflow.Views.ModelConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 模型节点配置"  Height="600" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource StandardDialogStyle}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="核心模型配置" Grid.Row="0" Style="{StaticResource StandardGroupBoxStyle}">
            <StackPanel Margin="5">
                <TextBlock Text="ONNX 模型路径:"/>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtModelPath" VerticalContentAlignment="Center" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="浏览" Width="60" Margin="5,0" Click="BtnBrowse_Click"
                            Style="{StaticResource SecondaryButtonStyle}"/>

                    <Button Grid.Column="2" Content="👁️ 可视化模型结构" Width="130" Click="BtnViewStructure_Click"
                            Background="#007ACC" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="推理引擎模式" Grid.Row="1" Style="{StaticResource StandardGroupBoxStyle}" Margin="0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <RadioButton x:Name="RbStandard" Content="模式一：标准级联" IsChecked="True" Checked="Mode_Changed"/>
                <RadioButton x:Name="RbSlicing" Content="模式二：特征切片共享" Margin="20,0,0,0" Checked="Mode_Changed"/>
            </StackPanel>
        </GroupBox>

        <GroupBox x:Name="GbSlicingConfig" Header="特征空间映射参数" Grid.Row="2" Style="{StaticResource StandardGroupBoxStyle}" Visibility="Collapsed">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="计算图切片角色:"/>
                    <ComboBox x:Name="CmbSliceRole" Margin="0,5,10,0">
                        <ComboBoxItem Content="Backbone (特征提取)"/>
                        <ComboBoxItem Content="Head (推理头)"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="降采样步长 (Stride):"/>
                    <TextBox x:Name="TxtStride" Text="8" Margin="0,5,0,0" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Header="可视化类别关注 (过滤机制)" Grid.Row="3" Style="{StaticResource StandardGroupBoxStyle}" Margin="0,10">
            <StackPanel Margin="5">
                <TextBlock Text="专注类别 ID (留空则全显):"/>
                <ComboBox x:Name="CmbTargetClass" IsEditable="True" Margin="0,5,0,0" VerticalContentAlignment="Center" />
                <TextBlock Text="提示：设置后，系统将忽略非专注类别的推理结果。" Margin="0,5" Foreground="Gray" FontSize="10"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存配置" Width="100" Click="BtnOk_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="取消" Width="80" Click="BtnCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>