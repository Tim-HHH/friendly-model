<Window x:Class="ModelHotSwapWorkflow.Views.ActionConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="动作节点配置" Width="350" Height="150" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal" Margin="5">
            <TextBlock Text="动作名称:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="ActionNameBox" Width="180" Text="写日志"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="5">
            <TextBlock Text="参数:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="ParamBox" Width="180" Text=""/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="确定" Width="70" Margin="5" Click="Ok_Click"/>
            <Button Content="取消" Width="70" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>