<Window x:Class="ModelHotSwapWorkflow.Views.ActionConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IO 动作执行配置" 
        SizeToContent="WidthAndHeight" MinWidth="450" MinHeight="250"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Style="{StaticResource StandardDialogStyle}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="动作类型" Grid.Row="0" Style="{StaticResource StandardGroupBoxStyle}">
            <ComboBox x:Name="CmbActionType" Width="240" HorizontalAlignment="Left" SelectionChanged="CmbActionType_SelectionChanged">
                <ComboBoxItem Content="1. 打印控制台日志 (调试用)"/>
                <ComboBoxItem Content="2. 导出生产报表 (CSV文件)"/>
                <ComboBoxItem Content="3. 推送结果至上位机 (HTTP)"/>
            </ComboBox>
        </GroupBox>

        <GroupBox Header="动作参数配置" Grid.Row="1" Style="{StaticResource StandardGroupBoxStyle}">
            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="备注信息:" Width="65" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMessage" Width="250" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="PnlCsvPath" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="导出目录:" Width="65" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtCsvPath" Width="200" VerticalAlignment="Center"/>
                    <Button Content="浏览" Width="50" Margin="10,0,0,0" Click="BtnBrowseCsv_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="5,2"/>
                </StackPanel>

                <StackPanel x:Name="PnlHttpUrl" Orientation="Horizontal" Visibility="Collapsed" Margin="0,10,0,0">
                    <TextBlock Text="回调地址:" Width="65" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPushUrl" Width="250" VerticalAlignment="Center" ToolTip="上位机接收结果的接口地址"/>
                </StackPanel>

            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="确定配置" Width="90" Click="BtnOk_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="取消" Width="70" Click="BtnCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>