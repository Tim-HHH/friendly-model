<Window x:Class="ModelHotSwapWorkflow.Views.DisplayConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="结果显示渲染配置" Height="300" Width="450"
        Style="{StaticResource StandardDialogStyle}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="视觉渲染设置" Grid.Row="0" Style="{StaticResource StandardGroupBoxStyle}">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="ChkDrawBox" Content="绘制检测边框 (红框)" Margin="0,0,20,0" IsChecked="True"/>
                <CheckBox x:Name="ChkDrawLabel" Content="绘制类别标签 (黄字)" IsChecked="True"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="不良品固化存储 (坏样保存)" Grid.Row="1" Style="{StaticResource StandardGroupBoxStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="保存目录:" VerticalAlignment="Center" Width="60"/>
                <TextBox x:Name="TxtSavePath" Width="240" VerticalAlignment="Center" ToolTip="为空则不保存"/>
                <Button Content="浏览" Width="60" Margin="10,0,0,0" Click="BtnBrowse_Click"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定配置" Width="90" Click="BtnOk_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="取消" Width="70" Click="BtnCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>