<Window x:Class="ModelHotSwapWorkflow.Views.BranchConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="逻辑分支分发配置" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Style="{StaticResource StandardDialogStyle}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="默认备用路由 (兜底分支)" Grid.Row="0" Margin="0,0,0,10" BorderBrush="#007ACC">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="未命中任何条件时，流向节点：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="CmbDefaultTarget" DisplayMemberPath="Name" SelectedValuePath="Id" Width="180"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="精确特征路由表 (例如填入 OK, NG, 极柱 等)" Grid.Row="1" BorderBrush="#007ACC">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="IcConditions">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Text="{Binding ConditionText}" Width="100" Margin="0,0,10,0" ToolTip="输入判定的字符串条件"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableNodes}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding TargetNodeId}"/>
                                    <Button Grid.Column="2" Content="❌" Width="30" Margin="10,0,0,0" ToolTip="删除此路由规则" Click="BtnRemoveCondition_Click" Tag="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="1" Content="+ 添加新路由规则" Click="BtnAddCondition_Click" Height="30" Margin="0,10,0,0" Background="#E1F0FF"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,15">
            <TextBlock Text="基础置信度阈值 (0.0~1.0)：" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtThreshold" Width="60" TextAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确认保存" Width="100" Height="35" Click="BtnOk_Click" Background="#007ACC" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="取消" Width="80" Height="35" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>