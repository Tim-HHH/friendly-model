<Window x:Class="ModelHotSwapWorkflow.Views.BranchConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="分支节点配置" Height="350" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="条件值 → 目标节点映射" FontWeight="Bold" Margin="0,0,0,5"/>

        <DataGrid x:Name="MappingGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="条件值" Binding="{Binding Condition}" Width="100"/>
                <DataGridComboBoxColumn x:Name="TargetComboColumn" Header="目标节点"
                                        SelectedItemBinding="{Binding TargetNodeName}"
                                        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 操作按钮行 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="➕ 添加条件" Width="100" Margin="0,0,10,0" Click="AddMapping_Click"/>
            <Button Content="➖ 删除选中" Width="100" Click="DeleteMapping_Click"/>
        </StackPanel>

        <!-- 确认/取消按钮行 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Width="70" Margin="5" Click="Ok_Click"/>
            <Button Content="取消" Width="70" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>