<UserControl x:Class="ModelHotSwapWorkflow.SelectableLine"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Canvas.ZIndex="-1">
    <Grid>
        <Path x:Name="HitTestPath" Stroke="Transparent" StrokeThickness="20" Cursor="Hand"
              MouseLeftButtonDown="HitTestPath_MouseLeftButtonDown">
            <Path.Data>
                <PathGeometry>
                    <PathFigure x:Name="HitFigure">
                        <BezierSegment x:Name="HitBezier" />
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
        </Path>

        <Path x:Name="MainPath" Stroke="#007ACC" StrokeThickness="3" IsHitTestVisible="False">
            <Path.Data>
                <PathGeometry>
                    <PathFigure x:Name="LineFigure">
                        <BezierSegment x:Name="BezierSeg" />
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
            <Path.Effect>
                <DropShadowEffect Color="#00A2FF" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
            </Path.Effect>
        </Path>
    </Grid>
</UserControl>