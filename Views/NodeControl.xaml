<UserControl x:Class="ModelHotSwapWorkflow.Views.NodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="90" Height="55"
             MouseEnter="NodeControl_MouseEnter"
             MouseLeave="NodeControl_MouseLeave">
    <Grid>
        <!-- 主内容边框 -->
        <Border x:Name="MainBorder" Background="White" BorderBrush="#888" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 标题栏 -->
                <Border Grid.Row="0" Background="#3C7FB1" CornerRadius="6,6,0,0">
                    <TextBlock x:Name="TitleText" Text="节点" Foreground="White" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="4,0,0,0" FontSize="9"/>
                </Border>
                <!-- 内容区 -->
                <StackPanel Grid.Row="1" Margin="4,2">
                    <TextBlock x:Name="ConfigDisplay" Text="双击配置" Foreground="Gray" FontSize="8" TextWrapping="Wrap"/>
                    
                </StackPanel>
            </Grid>
        </Border>

        <!-- 四个连接点（与 MainBorder 同级，基于整个控件尺寸对齐） -->
        <!-- 上连接点 -->
        <Ellipse x:Name="TopConnector" Width="8" Height="8" Fill="Red" Stroke="White" StrokeThickness="1"
                 HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-4,0,0"
                 Cursor="Cross" Visibility="Collapsed"
                 MouseLeftButtonDown="TopConnector_MouseLeftButtonDown"/>
        <!-- 下连接点 -->
        <Ellipse x:Name="BottomConnector" Width="8" Height="8" Fill="Red" Stroke="White" StrokeThickness="1"
                 HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-4"
                 Cursor="Cross" Visibility="Collapsed"
                 MouseLeftButtonDown="BottomConnector_MouseLeftButtonDown"/>
        <!-- 左连接点 -->
        <Ellipse x:Name="LeftConnector" Width="8" Height="8" Fill="Green" Stroke="White" StrokeThickness="1"
                 HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-4,0,0,0"
                 Cursor="Cross" Visibility="Collapsed"
                 MouseLeftButtonDown="LeftConnector_MouseLeftButtonDown"/>
        <!-- 右连接点 -->
        <Ellipse x:Name="RightConnector" Width="8" Height="8" Fill="Green" Stroke="White" StrokeThickness="1"
                 HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-4,0"
                 Cursor="Cross" Visibility="Collapsed"
                 MouseLeftButtonDown="RightConnector_MouseLeftButtonDown"/>
    </Grid>
</UserControl>