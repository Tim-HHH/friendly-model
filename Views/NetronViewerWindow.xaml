<Window x:Class="ModelHotSwapWorkflow.Views.NetronViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AI 模型计算图分析器 (基于 Netron)" Height="800" Width="1100"
        WindowStartupLocation="CenterOwner" Background="#2D2D2D">
    <Grid>
        <wv2:WebView2 x:Name="NetronBrowser" Source="https://netron.app"/>

        <Border x:Name="LoadingOverlay" Background="#F02D2D2D" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="正在连接可视化渲染引擎..." Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
                <TextBlock Text="请稍候..." Foreground="Gray" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>