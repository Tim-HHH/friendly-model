<Window x:Class="ModelHotSwapWorkflow.Views.ImageSourceConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图像采集源配置" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" Background="#2D2D2D" Foreground="White"
        ResizeMode="NoResize"
        Style="{StaticResource StandardDialogStyle}" >
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="图像采集参数设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="采集模式 (Collection Mode):" Foreground="#AAAAAA" Margin="0,5"/>
                <ComboBox x:Name="ModeComboBox" Height="30" Background="#3E3E42" Foreground="#3E3E42" SelectedIndex="0">
                    <ComboBoxItem Content="单张文件 (Single File)"/>
                    <ComboBoxItem Content="文件夹遍历 (Folder Sequence)"/>
                </ComboBox>

                <TextBlock Text="资源路径 (Source Path):" Margin="0,15,0,5" Foreground="#AAAAAA"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathTextBox" Height="30" IsReadOnly="True" Background="#3E3E42" Foreground="White" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="选择..." Click="Browse_Click" Margin="5,0,0,0" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                </Grid>

                <TextBlock Text="采集间隔 (Interval - ms):" Margin="0,15,0,5" Foreground="#AAAAAA"/>
                <TextBox x:Name="IntervalTextBox" Height="30" Text="1000" Background="#3E3E42" Foreground="White" VerticalContentAlignment="Center"/>

                <Border BorderBrush="#555555" BorderThickness="1" Margin="0,20,0,0" Padding="10">
                    <StackPanel>
                        <TextBlock Text="预处理设置 (Pre-processing)" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gold"/>
                        <CheckBox x:Name="GrayscaleCheckBox" Content="强制转为灰度图" Foreground="White" Margin="0,5"/>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="缩放宽度 (Width):" FontSize="11" Foreground="#AAAAAA"/>
                                <TextBox x:Name="ResizeWidthBox" Text="0" Background="#3E3E42" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="缩放高度 (Height):" FontSize="11" Foreground="#AAAAAA"/>
                                <TextBox x:Name="ResizeHeightBox" Text="0" Background="#3E3E42" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="* 设为 0 则保持原图尺寸" FontSize="10" Foreground="#666666" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="应用配置" Click="Ok_Click" Width="100" Height="30" Margin="10,0" Background="#28A745" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="Cancel_Click" Width="80" Height="30" Background="#6C757D" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>